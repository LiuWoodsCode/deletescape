{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build RootFS",
            "type": "shell",
            "command": "python",
            "args": [
                "builder/build.py",
                "--source-root",
                "${workspaceFolder}",
                "--output",
                "${workspaceFolder}/output.zip"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}